# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_convai_agent_id
ELEVENLABS_AGENT_TEMPLATE_ID=your_template_id

# Matching config (optional, defaults shown)
MATCH_SCORE_THRESHOLD=0.72
MATCH_CRON_SCHEDULE=0 */2 * * *
SIMILARITY_THRESHOLD=0.65
SIMILARITY_CANDIDATE_COUNT=5
