# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Google AI (Gemini — get free key at aistudio.google.com)
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_convai_agent_id

# Matching config (optional, defaults shown)
MATCH_SCORE_THRESHOLD=0.72
MATCH_CRON_SCHEDULE=0 */2 * * *
SIMILARITY_THRESHOLD=0.65
SIMILARITY_CANDIDATE_COUNT=5
